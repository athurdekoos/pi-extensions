{
  "name": "pi-subagents",
  "version": "0.1.0",
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "dependencies": {
    "@mariozechner/pi-ai": "latest",
    "@mariozechner/pi-coding-agent": "latest",
    "@sinclair/typebox": "latest"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "test": "vitest run --exclude 'tests/llm/**'",
    "test:all": "vitest run",
    "test:llm": "vitest run tests/llm/",
    "test:unit": "vitest run tests/unit/",
    "test:extension": "vitest run tests/extension/",
    "test:integration": "vitest run tests/integration/",
    "test:veracity": "vitest run tests/veracity/",
    "test:smoke": "vitest run tests/smoke/",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@esbuild/linux-arm64": "^0.27.4",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.18",
    "esbuild": "^0.19.12",
    "esbuild-wasm": "^0.27.4",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "vitest": "latest"
  }
}
